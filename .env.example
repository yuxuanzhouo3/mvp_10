# OpenAI-compatible AI provider
# OpenAI:
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Alibaba Cloud Bailian / DashScope:
# DASHSCOPE_API_KEY=your_dashscope_api_key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
# OPENAI_TRANSCRIBE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

OPENAI_API_KEY=
DASHSCOPE_API_KEY=
ENABLE_AI_ASSESSMENT_GENERATION=1
ENABLE_AI_RESUME_ANALYSIS=1
OPENAI_ASSESSMENT_GENERATION_MODEL=qwen-turbo
OPENAI_ASSESSMENT_MODEL=qwen3.5-plus
OPENAI_RESUME_ANALYSIS_MODEL=qwen-turbo
OPENAI_RESUME_MODEL=qwen3.5-plus
OPENAI_TRANSCRIBE_MODEL=qwen3-asr-flash
OPENAI_TRANSCRIPT_NORMALIZE_MODEL=qwen3.5-plus
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
OPENAI_TRANSCRIBE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1

# CloudBase
CLOUDBASE_ENV_ID=your-cloudbase-env-id
CLOUDBASE_PREFER_LOCAL=0

# Optional: set either Tencent Cloud secret pair or CloudBase API key
TENCENTCLOUD_SECRETID=your-tencent-cloud-secret-id
TENCENTCLOUD_SECRETKEY=your-tencent-cloud-secret-key
TENCENTCLOUD_SESSIONTOKEN=
CLOUDBASE_APIKEY=

# Optional: specify a non-default CloudBase database / instance
CLOUDBASE_DATABASE_NAME=
CLOUDBASE_DATABASE_INSTANCE=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=

# Auth
AUTH_JWT_SECRET=
CLOUDBASE_AUTH_CLIENT_ID=
CLOUDBASE_AUTH_BASE_URL=

# Optional app settings
NEXT_PUBLIC_WS_URL=
PLATFORM_NAME=
RECRUITING_SUPPORT_EMAIL=
INTERVIEW_SCHEDULING_URL=
EMPLOYER_ONBOARDING_URL=
EMPLOYER_DEMO_URL=
PAYMENT_CHECKOUT_URL_TEMPLATE=
APP_URL=http://localhost:3000

# Optional local fallback storage root
# LOCAL_DATA_DIR=/tmp/mvp_10-data

# WeChat Pay v3
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com
